{
	"name": "itzmekhokan/sitecargo",
	"description": "SiteCargo — selectively promote WordPress FSE structure and content (patterns, templates, parts, global styles, navigation) between environments, without a full database migration.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"homepage": "https://github.com/itzmekhokan/sitecargo",
	"keywords": [
		"wordpress",
		"fse",
		"block-themes",
		"migration",
		"staging",
		"deployment"
	],
	"authors": [
		{
			"name": "Khokan Sardar",
			"homepage": "https://github.com/itzmekhokan",
			"role": "Developer"
		}
	],
	"support": {
		"issues": "https://github.com/itzmekhokan/sitecargo/issues",
		"source": "https://github.com/itzmekhokan/sitecargo"
	},
	"require": {
		"php": ">=7.4",
		"composer/installers": "^1.0 || ^2.0"
	},
	"require-dev": {
		"yoast/phpunit-polyfills": "^2.0 || ^3.0"
	},
	"autoload": {
		"psr-4": {
			"SiteCargo\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"SiteCargo\\Tests\\": "tests/"
		}
	},
	"config": {
		"allow-plugins": {
			"composer/installers": true,
			"dealerdirect/phpcodesniffer-composer-installer": true
		},
		"sort-packages": true
	},
	"scripts": {
		"test": "phpunit"
	}
}
